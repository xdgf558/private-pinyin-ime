<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="猫栈拼音"
    Language="1033"
    Codepage="936"
    Version="$(var.ProductVersion)"
    Manufacturer="猫栈"
    UpgradeCode="2B3455F6-25ED-4BCB-8871-BE5B63C3875F">
    <Package
      InstallerVersion="500"
      Compressed="yes"
      Platform="$(var.PackagePlatform)"
      InstallScope="perUser"
      SummaryCodepage="936"
      Description="猫栈拼音 Windows TSF 输入法" />

    <MajorUpgrade DowngradeErrorMessage="已经安装了更新版本的猫栈拼音。" />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="猫栈拼音" Level="1">
      <ComponentGroupRef Id="PrivatePinyinComponents" />
    </Feature>

    <CustomAction
      Id="RegisterTsf64"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;$(var.RegSvr32Path64)&quot; /s &quot;[#PrivatePinyinTsfDllX64]&quot;"
      Execute="deferred"
      Impersonate="yes"
      Return="check" />
    <CustomAction
      Id="RegisterTsf32"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;$(var.RegSvr32Path32)&quot; /s &quot;[#PrivatePinyinTsfDllX86]&quot;"
      Execute="deferred"
      Impersonate="yes"
      Return="check" />
    <CustomAction
      Id="UnregisterTsf64"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;$(var.RegSvr32Path64)&quot; /u /s &quot;[#PrivatePinyinTsfDllX64]&quot;"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />
    <CustomAction
      Id="UnregisterTsf32"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;$(var.RegSvr32Path32)&quot; /u /s &quot;[#PrivatePinyinTsfDllX86]&quot;"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="UnregisterTsf32" Before="UnregisterTsf64">REMOVE="ALL"</Custom>
      <Custom Action="UnregisterTsf64" Before="RemoveFiles">REMOVE="ALL"</Custom>
      <Custom Action="RegisterTsf64" After="InstallFiles">NOT REMOVE~="ALL"</Custom>
      <Custom Action="RegisterTsf32" After="RegisterTsf64">NOT REMOVE~="ALL"</Custom>
    </InstallExecuteSequence>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLFOLDER" Name="PrivatePinyin">
          <Directory Id="X64FOLDER" Name="x64" />
          <Directory Id="X86FOLDER" Name="x86" />
          <Directory Id="WRITERRUNTIMEFOLDER" Name="WriterRuntime" />
        </Directory>
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="PrivatePinyinComponents">
      <Component Id="PrivatePinyinTsfDllX64Component" Directory="X64FOLDER" Guid="91F61764-B5D5-4E0C-B13F-A194EE25DE19" Win64="yes">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="TsfDllX64" Type="integer" Value="1" KeyPath="yes" />
        <RemoveFolder Id="RemoveX64Folder" Directory="X64FOLDER" On="uninstall" />
        <File Id="PrivatePinyinTsfDllX64" Source="$(var.PackageSource)\x64\PrivatePinyinTsf.dll" />
        <File Id="PrivatePinyinInstallerIconX64" Source="$(var.PackageSource)\x64\PrivatePinyinInstaller.ico" />
      </Component>
      <Component Id="PrivatePinyinFfiDllX64Component" Directory="X64FOLDER" Guid="0FD34CE8-6F87-48AF-A442-01D4490287B2" Win64="yes">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="FfiDllX64" Type="integer" Value="1" KeyPath="yes" />
        <File Id="PrivatePinyinFfiDllX64" Source="$(var.PackageSource)\x64\private_pinyin_ime.dll" />
      </Component>
      <Component Id="PrivatePinyinTsfDllX86Component" Directory="X86FOLDER" Guid="A4C9B63B-756B-4709-9B40-9D5C92D1D8E6" Win64="no">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="TsfDllX86" Type="integer" Value="1" KeyPath="yes" />
        <RemoveFolder Id="RemoveX86Folder" Directory="X86FOLDER" On="uninstall" />
        <File Id="PrivatePinyinTsfDllX86" Source="$(var.PackageSource)\x86\PrivatePinyinTsf.dll" />
        <File Id="PrivatePinyinInstallerIconX86" Source="$(var.PackageSource)\x86\PrivatePinyinInstaller.ico" />
      </Component>
      <Component Id="PrivatePinyinFfiDllX86Component" Directory="X86FOLDER" Guid="6CF25AC7-FB6A-4300-92B0-48DB307EA5DB" Win64="no">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="FfiDllX86" Type="integer" Value="1" KeyPath="yes" />
        <File Id="PrivatePinyinFfiDllX86" Source="$(var.PackageSource)\x86\private_pinyin_ime.dll" />
      </Component>
      <Component Id="PrivatePinyinSettingsToolComponent" Directory="INSTALLFOLDER" Guid="050BB8F6-A41F-44D7-BA89-497D94425CCE" Win64="$(var.ComponentWin64)">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="SettingsTool" Type="integer" Value="1" KeyPath="yes" />
        <File Id="PrivatePinyinSettingsTool" Source="$(var.PackageSource)\private-pinyin-settings.exe" />
      </Component>
      <Component Id="PrivatePinyinAIHelperComponent" Directory="INSTALLFOLDER" Guid="E9C0D7D2-5E5C-4DE5-9FC1-860E65D0D2B9" Win64="$(var.ComponentWin64)">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="AIHelper" Type="integer" Value="1" KeyPath="yes" />
        <File Id="PrivatePinyinAIHelper" Source="$(var.PackageSource)\PrivatePinyinAIHelper.exe" />
      </Component>
      <Component Id="PrivatePinyinWriterRuntimeComponent" Directory="WRITERRUNTIMEFOLDER" Guid="AB3D2834-9B6A-4E68-8962-F34DE9D673B8" Win64="$(var.ComponentWin64)">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="WriterRuntime" Type="integer" Value="1" KeyPath="yes" />
        <RemoveFolder Id="RemoveWriterRuntimeFolder" Directory="WRITERRUNTIMEFOLDER" On="uninstall" />
        <File Id="WriterLlamaServer" Source="$(var.PackageSource)\WriterRuntime\llama-server.exe" />
        <File Id="WriterLlamaServerImpl" Source="$(var.PackageSource)\WriterRuntime\llama-server-impl.dll" />
        <File Id="WriterLlamaCommon" Source="$(var.PackageSource)\WriterRuntime\llama-common.dll" />
        <File Id="WriterLlama" Source="$(var.PackageSource)\WriterRuntime\llama.dll" />
        <File Id="WriterGgml" Source="$(var.PackageSource)\WriterRuntime\ggml.dll" />
        <File Id="WriterGgmlBase" Source="$(var.PackageSource)\WriterRuntime\ggml-base.dll" />
        <File Id="WriterGgmlCpuX64" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-x64.dll" />
        <File Id="WriterGgmlCpuAlderlake" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-alderlake.dll" />
        <File Id="WriterGgmlCpuCannonlake" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-cannonlake.dll" />
        <File Id="WriterGgmlCpuCascadelake" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-cascadelake.dll" />
        <File Id="WriterGgmlCpuCooperlake" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-cooperlake.dll" />
        <File Id="WriterGgmlCpuHaswell" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-haswell.dll" />
        <File Id="WriterGgmlCpuIcelake" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-icelake.dll" />
        <File Id="WriterGgmlCpuIvybridge" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-ivybridge.dll" />
        <File Id="WriterGgmlCpuPiledriver" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-piledriver.dll" />
        <File Id="WriterGgmlCpuSandybridge" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-sandybridge.dll" />
        <File Id="WriterGgmlCpuSapphirerapids" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-sapphirerapids.dll" />
        <File Id="WriterGgmlCpuSkylakex" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-skylakex.dll" />
        <File Id="WriterGgmlCpuSse42" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-sse42.dll" />
        <File Id="WriterGgmlCpuZen4" Source="$(var.PackageSource)\WriterRuntime\ggml-cpu-zen4.dll" />
        <File Id="WriterLibomp" Source="$(var.PackageSource)\WriterRuntime\libomp140.x86_64.dll" />
        <File Id="WriterMtmd" Source="$(var.PackageSource)\WriterRuntime\mtmd.dll" />
        <File Id="WriterRuntimeLicense" Source="$(var.PackageSource)\WriterRuntime\llama.cpp-LICENSE.txt" />
      </Component>
      <Component Id="PrivatePinyinInstallerScriptsComponent" Directory="INSTALLFOLDER" Guid="F6453682-606E-4937-88FF-B006577798FB" Win64="$(var.ComponentWin64)">
        <RegistryValue Root="HKCU" Key="Software\PrivatePinyin\Installer" Name="InstallerScripts" Type="integer" Value="1" KeyPath="yes" />
        <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
        <File Id="RegisterImeScript" Source="$(var.PackageSource)\register-ime.ps1" />
        <File Id="UnregisterImeScript" Source="$(var.PackageSource)\unregister-ime.ps1" />
        <File Id="OpenSettingsScript" Source="$(var.PackageSource)\open-settings.ps1" />
        <File Id="OpenWriterScript" Source="$(var.PackageSource)\open-writer.ps1" />
        <File Id="OpenOnboardingScript" Source="$(var.PackageSource)\open-onboarding.ps1" />
        <File Id="PrivatePinyinLogo" Source="$(var.PackageSource)\PrivatePinyinLogo.png" />
        <File Id="ReleaseNotesZhHans" Source="$(var.PackageSource)\ReleaseNotes.zh-Hans.txt" />
        <File Id="DefaultSettingsJson" Source="$(var.PackageSource)\default_settings.json" />
        <File Id="VersionTxt" Source="$(var.PackageSource)\version.txt" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
