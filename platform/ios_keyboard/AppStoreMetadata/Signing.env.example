# Copy this file to Signing.env and fill in owner-specific values.
# Signing.env is ignored so local Apple Developer identifiers are not committed.

export PRIVATE_PINYIN_IOS_TEAM_ID="TEAMID1234"
export PRIVATE_PINYIN_IOS_APP_BUNDLE_ID="com.privatepinyin.ios"
export PRIVATE_PINYIN_IOS_KEYBOARD_BUNDLE_ID="com.privatepinyin.ios.keyboard"
export PRIVATE_PINYIN_IOS_APP_GROUP_ID="group.com.privatepinyin.ios"
export PRIVATE_PINYIN_IOS_EXPORT_OPTIONS="platform/ios_keyboard/AppStoreMetadata/ExportOptions.plist"

# Optional, required when ExportOptions.plist uses destination=upload.
# export PRIVATE_PINYIN_IOS_DISTRIBUTION_MODE="upload"
# export PRIVATE_PINYIN_IOS_ASC_KEY_PATH="$HOME/private_keys/AuthKey_ABC123DEFG.p8"
# export PRIVATE_PINYIN_IOS_ASC_KEY_ID="ABC123DEFG"
# export PRIVATE_PINYIN_IOS_ASC_ISSUER_ID="00000000-0000-0000-0000-000000000000"
